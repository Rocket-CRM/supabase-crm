# CRM MCP Server — environment variables
# Copy this file to .env and fill in the values.
# Each role/merchant combo gets their own .env (or separate named env files).

# Supabase project URL — same for all users
SUPABASE_URL=https://wkevmsedchftztoolkmi.supabase.co

# Supabase anon key — public key, safe to share within the team
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Credentials for the named role user in Supabase Auth
# This user must exist in auth.users AND in the admin_users table
# with active_status=true and a role_id pointing to admin_roles.role_code
CRM_EMAIL=tester@yourmerchant.internal
CRM_PASSWORD=your_secure_password_here
